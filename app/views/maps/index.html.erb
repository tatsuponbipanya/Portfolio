<% provide(:title, "Map") %>
<h3>マップ</h3>
旅行先の下調べ等にご利用下さい。
<input id="address" type="textbox" placeholder="検索したい場所を入力">

<input type="button" value="検索" onclick="codeAddress()">
<div id='map'>
</div>

<style>
#map{
  height: 600px;
}
</style>

<script>
/*
【Turbo対策】
何度も let で同じ変数を宣言するとエラーになるため、
すでに存在していなければ初期化する、という書き方に変更する
*/
window.map = window.map || null;
window.geocoder = window.geocoder || null;

function initMap(){
  const mapElement = document.getElementById('map');
  if (!mapElement) return; // 画面に#mapがなければ何もしない（エラー予防）

  // geocoderを初期化（すでになければ作る）
  if (!window.geocoder) {
    window.geocoder = new google.maps.Geocoder();
  }

  // 地図の初期化（東京駅を中心に設定）
  window.map = new google.maps.Map(mapElement, {
    center: {lat: 35.681228, lng: 139.767052},
    zoom: 12
  });
}

function codeAddress(){
  // 入力を取得
  let inputAddress = document.getElementById('address').value;

  // geocoderが準備できていなければ処理しない
  if (!window.geocoder) return;

  // geocodingしたあとmapを移動
  window.geocoder.geocode( { 'address': inputAddress}, function(results, status) {
    if (status == 'OK') {
      // map.setCenterで地図が移動
      window.map.setCenter(results[0].geometry.location);

      // google.maps.MarkerでGoogleMap上の指定位置にマーカが立つ
      var marker = new google.maps.Marker({
          map: window.map,
          position: results[0].geometry.location
      });
    } else {
      alert('見つかりませんでした。検索キーワードに誤字や脱字がないかご確認ください。地名や郵便番号を追加してみてください。');
    }
  });
}

/* 【ここが一番大事！】
Railsの画面遷移（Turbo）が発生したときに、
すでにGoogleマップが読み込まれていたら手動で地図を初期化するおまじない
*/
document.addEventListener("turbo:load", function() {
  if (typeof google !== 'undefined' && google.maps) {
    initMap();
  }
});
</script>

<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCtdZ2kpdgmGomePA2LXqc4Y4gWq5hF92k" async defer></script>