<% provide(:title, "Map") %>
<h3>マップ</h3>
旅行先の下調べ等にご利用下さい。
<input id="address" type="textbox" placeholder="検索したい場所を入力">

<input type="button" value="検索" onclick="codeAddress()">
<div id='map'>
</div>

<style>
#map{
  height: 600px;
}
</style>

<script>
// グローバル変数の重複宣言を防ぐおまじない
window.map = window.map || null;
window.geocoder = window.geocoder || null;

// 地図を初期化する本番関数
function initMap(){
  const mapElement = document.getElementById('map');
  if (!mapElement) return; // 画面に#mapがなければ何もしない

  if (!window.geocoder) {
    window.geocoder = new google.maps.Geocoder();
  }

  window.map = new google.maps.Map(mapElement, {
    center: {lat: 35.681228, lng: 139.767052}, // 東京駅中心
    zoom: 12
  });
}

function codeAddress(){
  let inputAddress = document.getElementById('address').value;
  if (!window.geocoder) return;

  window.geocoder.geocode( { 'address': inputAddress}, function(results, status) {
    if (status == 'OK') {
      window.map.setCenter(results[0].geometry.location);
      var marker = new google.maps.Marker({
          map: window.map,
          position: results[0].geometry.location
      });
    } else {
      alert('見つかりませんでした。検索キーワードに誤字や脱字がないかご確認ください。地名や郵便番号を追加してみてください。');
    }
  });
}

// ページが切り替わったときのTurbo対策
document.addEventListener("turbo:load", function() {
  if (typeof google !== 'undefined' && google.maps) {
    // すでにGoogleが読み込まれていたら、関数を呼ぶだけで地図を作る
    initMap();
  } else {
    // まだ読み込まれていなければ、1回だけスクリプトを生成して埋め込む（二重読み込み防止！）
    if (!document.getElementById('google-maps-api-script')) {
      const script = document.createElement('script');
      script.src = "https://maps.googleapis.com/maps/api/js?key=AIzaSyCtdZ2kpdgmGomePA2LXqc4Y4gWq5hF92k";
      script.id = 'google-maps-api-script';
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    }
  }
});
</script>